PORT=5000
NODE_ENV=development

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# CatVTON API
CATVTON_API_URL=http://localhost:7860
CATVTON_API_KEY=

# OpenRouter API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
